# Copy to .env and adjust

# LLM provider (chat/completion): ollama | openai | nim
# Default local Ollama — cost $0, shows self-hosted capability.
LLM_PROVIDER=ollama

# Embedding provider — sticky to the Qdrant collection's vector dim.
# Ollama(nomic)=768, NIM(nv-embedqa)=1024, OpenAI(small)=1536.
# Switching requires re-indexing the collection.
EMBED_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional — used by cost-comparison middleware)
# Leave empty if you don't want API fallback
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# NIM (optional — hosted NVIDIA inference)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_LLM_MODEL=meta/llama-3.3-70b-instruct
NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=properties
QDRANT_EF=64
QDRANT_M=16

# Redis (cache)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# App
APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=true

# Cost — USD per 1K tokens. Used for real cost (when provider is paid) and
# shadow cost (what the same tokens would have cost elsewhere).

# OpenAI gpt-4o-mini
OPENAI_GPT4O_MINI_INPUT_PER_1K=0.00015
OPENAI_GPT4O_MINI_OUTPUT_PER_1K=0.0006
OPENAI_EMBED_SMALL_PER_1K=0.00002

# NVIDIA NIM — meta/llama-3.3-70b-instruct, nv-embedqa-e5-v5
# Pricing source: build.nvidia.com (as of 2026-04; verify before prod use)
NIM_LLAMA70B_INPUT_PER_1K=0.0008
NIM_LLAMA70B_OUTPUT_PER_1K=0.0008
NIM_EMBED_PER_1K=0.000016
